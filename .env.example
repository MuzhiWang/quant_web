# Express BFF (server.js) configuration — copy to .env and edit.

# Port the BFF listens on. The React client calls this (default 3000).
PORT=3000

# Which FastAPI backend the BFF proxies /api/* to.
#  - Centralized Linux API (public):  https://api.your-host.example/api   <-- target setup
#  - Local Windows backend:           http://localhost:8001/api
#  - Mac via SSH tunnel (-L 8001):    http://localhost:8001/api
API_BASE_URL=http://localhost:8001/api

# Token for the centralized backend's write endpoints (/api/order, /api/cash). Must match
# the backend's QMT_API_TOKEN / [SECURITY] api_token. Kept server-side in the BFF and sent
# as X-API-Token — never exposed to the browser. Leave empty if the backend has no token.
API_TOKEN=

# CORS origin allowed by the BFF. Tighten in production (e.g. https://app.your-host.example).
CORS_ORIGIN=*
