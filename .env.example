# Express BFF (server.js) configuration — copy to .env and edit.

# Port the BFF listens on. The React client calls this (default 3000).
PORT=3000

# Which FastAPI backend the BFF proxies /api/* to.
#  - Local Windows backend:        http://localhost:8001/api
#  - Mac via SSH tunnel (-L 8001): http://localhost:8001/api
#  - Mac direct to remote host:    http://<windows-or-ecs-ip>:8001/api
API_BASE_URL=http://localhost:8001/api

# CORS origin allowed by the BFF. Tighten in production (e.g. http://localhost:3001).
CORS_ORIGIN=*
