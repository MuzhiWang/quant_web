# React client (CRA) configuration — copy to .env and edit.

# Dev server port. MUST differ from the BFF's port (3000) to avoid a collision.
PORT=3001

# The API base the client calls. Keep this pointed at the LOCAL BFF (:3000),
# not the FastAPI backend directly — the BFF handles remote proxying/CORS.
REACT_APP_API_BASE_URL=http://localhost:3000/api
